[
  {
    "id": "claude",
    "name": "Claude Code",
    "executable": "claude",
    "description": "Anthropic's agentic coding assistant. Operates in-terminal with full file and shell access.",
    "invocation": "claude -p \"your prompt here\"",
    "headless": {
      "style": "flag",
      "args": ["-p", "{prompt}"],
      "output_format_flag": "--output-format",
      "output_formats": ["text", "json", "stream-json"]
    },
    "version_args": ["--version"]
  },
  {
