    "executable": "codex",
    "description": "OpenAI's terminal-based coding agent with sandboxed execution.",
    "invocation": "codex exec \"your prompt here\"",
    "headless": {
      "style": "subcommand",
      "args": ["exec", "{prompt}"]
    },
    "version_args": ["--version"]
  },
  {
    "id": "copilot",
    "name": "GitHub Copilot CLI",
    "executable": "gh",
    "description": "GitHub's AI pair programmer, accessed via the gh CLI extension.",
    "invocation": "gh copilot -p \"your prompt here\" --allow-all-tools",
    "subcommand": "copilot",
    "headless": {
      "style": "subcommand",
      "args": ["copilot", "-p", "{prompt}", "--allow-all-tools"]
    },
    "version_args": ["copilot", "--", "--version"]
  },
  {
    "id": "gemini",
